# ============================================
# Vehicle Management System - Environment Variables
# ============================================

# --------------------------------------------
# MongoDB Configuration
# --------------------------------------------
# For Docker deployment:
MONGO_URI=mongodb://admin:securepassword@mongodb:27017/vehicle-management?authSource=admin

# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vehicle-management

# Root password for MongoDB container (only used in docker-compose)
MONGO_ROOT_PASSWORD=securepassword

# --------------------------------------------
# JWT Configuration
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# --------------------------------------------
# Cloudinary Configuration (for file uploads)
# Get these from https://cloudinary.com/console
# --------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --------------------------------------------
# Backend Configuration
# --------------------------------------------
PORT=4001
NODE_ENV=production

# CORS - Allowed frontend URL
# For production, set this to your actual domain
FRONTEND_URL=http://localhost:3000

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
# URL where backend API is accessible
NEXT_PUBLIC_API_URL=http://localhost:4001/api
